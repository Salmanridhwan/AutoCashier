{
  "name": "autocashier-admin",
  "version": "1.0.0",
  "private": true,
  "description": "AutoCashier Admin - Dashboard Frontend + Backend",
  "workspaces": [
    "frontend",
    "packages/*",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "npm run dev -w frontend",
    "dev:backend": "npm run dev -w backend",
    "build": "npm run build -w frontend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3"
  }
}
