# ===========================================
# AutoCashier Monorepo - .gitignore
# ===========================================

# Dependencies
node_modules/

# Build outputs
dist/
build/
*.tsbuildinfo

# Environment variables
.env
.env.local
.env.*.local
!.env.example

# Python (Vision Server)
.venv/
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
*.pt

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Testing
coverage/

# Misc
*.local

# ML / Vision exclusions
dataset/
models/
*.pth
*.onnx
*.safetensors

